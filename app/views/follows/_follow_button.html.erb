<% disabled = local_assigns.fetch(:disabled, false) %>

<% if current_user.following?(user) %>
  <%= button_to "Unfollow",
    user_follow_path(user),
    method: :delete,
    class: "btn btn-secondary text-sm",
    disabled: disabled %>
<% else %>
  <%= button_to "Follow",
    user_follow_path(user),
    method: :post,
    class: "btn btn-primary text-sm",
    disabled: disabled %>
<% end %>

