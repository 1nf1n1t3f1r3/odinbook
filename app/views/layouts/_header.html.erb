<header class="bg-primary-blue-dark text-white shadow">
  <nav class="container-main flex items-center justify-between py-4">

    <!-- Left: Logo -->
    <div class="font-bold text-xl">
      <%= link_to "Odinbook", root_path, class: "hover:text-accent-yellow" %>
    </div>

    <!-- Middle: Navigation -->
    <div class="flex gap-6 font-semibold">
      <%= link_to "Posts", root_path, class: "hover:text-accent-yellow" %>
      <%= link_to "Users", users_path, class: "hover:text-accent-yellow" %>
      <% if user_signed_in? %>
        <%= link_to "Profile", user_path(current_user), class: "hover:text-accent-yellow" %>
      <% end %>
    </div>

    <!-- Right: Auth -->
    <div class="flex items-center gap-4 text-sm">
      <% if user_signed_in? %>
        <span>Hi, <%= current_user.username %></span>
        <%= link_to "Logout",
            destroy_user_session_path,
            data: { turbo_method: :delete },
            class: "btn btn-primary" %>
      <% else %>
        <%= link_to "Login", new_user_session_path, class: "hover:text-accent-yellow" %>
        <%= link_to "Sign Up", new_user_registration_path, class: "btn btn-primary" %>
      <% end %>
    </div>

  </nav>
</header>