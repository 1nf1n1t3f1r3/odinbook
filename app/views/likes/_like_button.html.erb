<%# app/views/likes/_like_button.html.erb %>
<%= turbo_frame_tag "likes_for_#{dom_id(post)}" do %>
  <div class="flex items-center gap-2 mb-2">
    <% if post.liked_by?(current_user) %>
      <%= button_to "Unlike 💔",
                    post_like_path(post),
                    method: :delete,
                    class: "text-primary-blue-dark font-bold hover:text-accent-yellow" %>
    <% else %>
      <%# Note: Switched to post_like_path to match standard Rails nested routing %>
      <%= button_to "Like 🤍",
                    post_like_path(post),
                    method: :post,
                    class: "text-primary-blue-dark font-bold hover:text-accent-yellow" %>
    <% end %>
    <span class="text-sm text-gray-600">
      <%# Speed tip: Use likes_count instead of likes.count to utilize your counter cache column %>
      <%= post.likes_count %> likes
    </span>
  </div>
<% end %>