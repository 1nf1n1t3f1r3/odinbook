<div class="container-main">
  <div class="layout-3col">
    <!-- LEFT SIDEBAR -->
    <aside>
      <%= render "shared/left_sidebar" %>
    </aside>
    <!-- MAIN CONTENT -->
    <main class="space-y-6">
      <!-- PROFILE HEADER -->
      <div class="card card-hover">
        <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">
          <%= @user.username %>
        </h1>
        <% if @user.avatar.attached? %>
          <div class="mb-2">
            <%= image_tag @user.avatar, class: "w-16 h-16 rounded-full object-cover" %>
          </div>
        <% end %>
        <div class="mb-4">
          <p>
            <span class="font-semibold">Username:</span>
            <%= @user.username %>
          </p>
          <p>
            <span class="font-semibold">Email:</span>
            <%= @user.email %>
          </p>
        </div>
        <div class="mb-4">
        </div>
        <div class="mb-4 flex gap-6">
          <p><span class="font-semibold"><%= @user.posts.count %></span> Posts</p>
          <div class="mb-4 flex gap-6">
            <p><span class="font-semibold"><%= @user.posts.count %></span> Posts</p>
            <p class="hover:underline cursor-pointer">
              <%= link_to users_path(filter_by: "followers", user_id: @user.id, query: "#{@user.username}'s Followers") do %>
                <span id="followers_count_user_<%= @user.id %>" class="font-semibold text-primary-blue-dark">
                  <%= @user.followers.count %>
                </span> Followers
              <% end %>
            </p>
            <p class="hover:underline cursor-pointer">
              <%= link_to users_path(filter_by: "following", user_id: @user.id, query: "People #{@user.username} Follows") do %>
                <span class="font-semibold text-primary-blue-dark"><%= @user.following.count %></span> Following
              <% end %>
            </p>
          </div>
        </div>
        <% unless current_user == @user %>
          <div class="mt-2">
            <%= render "follows/follow_button", user: @user %>
          </div>
        <% end %>
      </div>
      <% if current_user == @user %>
        <div class="mt-4">
          <%= link_to "Edit Profile",
				profile_edit_path,
                class: "btn btn-primary self-start mt-2" %>
        </div>
      <% end %>
      <% if current_user == @user %>
        <div class="mt-4">
          <h2 class="text-xl font-bold text-primary-blue-dark mb-2">Create a Post</h2>
          <%= render "posts/create_post" %>
        </div>
      <% end %>
      <!-- POSTS HEADER -->
      <h2 class="text-xl font-bold text-primary-blue-dark">
        Posts
      </h2>
      <!-- POSTS LIST -->
      <% if @posts.any? %>
        <% # 1. The container where new user posts will cascade %>
        <div id="user-posts-container" class="space-y-4">
          <% @posts.each do |post| %>
            <%= render post %>
          <% end %>
        </div>
        <% # 2. The pagination observer target %>
        <%= turbo_frame_tag "pagy_pagination_frame" do %>
          <% if @pagy.next %>
            <div data-controller="infinite-scroll" class="my-8 text-center py-4">
              <%= link_to "Loading more posts...", 
                          user_path(@user, page: @pagy.next), 
                          data: { 
                            turbo_stream: true,
                            infinite_scroll_target: "link" 
                          }, 
                          class: "text-gray-500 text-sm tracking-wide animate-pulse" %>
            </div>
          <% end %>
        <% end %>
      <% else %>
        <div class="card">
          <p class="opacity-70">No posts yet.</p>
        </div>
      <% end %>
    </main>
    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card-white">
        <h2 class="font-semibold mb-2">
          User Profile Card
        </h2>
        <ul>
          <%= render "users/user",
				user: (@user || current_user),
				show_follow_button: false %>
        </ul>
      </div>
    </aside>
  </div>
</div>
