<div class="container-main">

  <div class="layout-3col">

    <!-- LEFT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Navigation</h2>
        <p class="text-sm opacity-70">Links coming later</p>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="space-y-6">

      <!-- PROFILE HEADER -->
      <div class="card card-hover">
        <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">
          <%= @user.username %>
        </h1>

        <p class="text-sm opacity-80">
          <span class="font-semibold">Username:</span>
          <%= @user.username %>
        </p>

        <p class="text-sm opacity-80">
          <span class="font-semibold">Email:</span>
          <%= @user.email %>
        </p>
      </div>

      <!-- POSTS HEADER -->

        <h2 class="text-xl font-semibold text-primary-blue-dark">
          Posts
        </h2>


      <!-- POSTS LIST -->
      <% if @posts.any? %>
        <div class="space-y-3">

          <% @posts.each do |post| %>
            <div class="card card-hover">

              <p class="mb-2">
                <%= post.content %>
              </p>

              <p class="text-xs opacity-60">
                <%= post.created_at.strftime("%b %d, %Y") %>
              </p>

            </div>
          <% end %>

        </div>
      <% else %>
        <div class="card">
          <p class="opacity-70">No posts yet.</p>
        </div>
      <% end %>

    </main>

    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Profile</h2>
        <p class="text-sm opacity-70">User stats later</p>
      </div>
    </aside>

  </div>

</div>