<h1>Edit Profile</h1>

<%= form_with model: @user, url: profile_path, method: :patch do |f| %>

  <div>
    <%= f.label :username %><br>
    <%= f.text_field :username %>
  </div>

  <div>
    <%= f.label :avatar %><br>
    <%= f.file_field :avatar %>
  </div>

  <div>
    <%= f.submit "Update Profile" %>
  </div>

<% end %>