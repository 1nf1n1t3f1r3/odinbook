<div class="container-main">
  <div class="flex justify-center">
    <div class="w-full max-w-md">
      <div class="card">
        <h2 class="text-2xl font-bold text-primary-blue-dark mb-6">
          Sign in
        </h2>
        <!-- Friendly recruiter note -->
        <p class="text-sm text-gray-500 mb-6">
          👋 Recruiter? Feel free to use the pre-filled guest account below!
        </p>
        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
          <div class="form-group">
            <%= f.label :email, class: "label" %>
            <%= f.email_field :email, autofocus: true, value: "guest@example.com", autocomplete: "email", class: "input" %>
          </div>
          <div class="form-group">
            <%= f.label :password, class: "label" %>
            <%= f.password_field :password, value: "guest@example.com", autocomplete: "current-password", class: "input" %>
          </div>
          <% if devise_mapping.rememberable? %>
            <div class="form-group flex items-center gap-2">
              <%= f.check_box :remember_me %>
              <%= f.label :remember_me, class: "text-sm" %>
            </div>
          <% end %>
          <div class="flex flex-col gap-2 mt-4">
            <%= f.submit "Log in", class: "btn btn-primary w-full" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>