<%# <h1>Posts#index</h1>
<p>Find me in app/views/posts/index.html.erb</p> %>

<div class="max-w-4xl mx-auto p-4">

  <!-- Create Post -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-blue-900 mb-2">Create a Post</h1>
    <%= form_with model: Post.new, url: posts_path, class: "flex flex-col gap-2" do |f| %>
      <%= f.text_area :content, placeholder: "What's on your mind?",
            class: "p-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-yellow-400" %>
      <%= f.submit "Post", class: "self-end px-4 py-2 bg-yellow-400 text-blue-900 font-semibold rounded-lg hover:bg-yellow-300" %>
    <% end %>
  </div>

  <!-- Feed -->
  <h1 class="text-2xl font-bold text-blue-900 mb-4">Feed</h1>

  <% @posts.each do |post| %>
    <div class="bg-blue-100 p-4 rounded-lg shadow mb-4">
      
      <div class="flex justify-between items-center mb-2">
        <strong>
          <%= link_to post.user.username, user_path(post.user),
                class: "text-blue-900 font-semibold hover:text-yellow-400" %>
        </strong>
        <small class="text-gray-600">
          <%= time_ago_in_words(post.created_at) %> ago
        </small>
      </div>

      <p class="mb-2 text-gray-800"><%= post.content %></p>

      <div class="flex gap-2">
        <%= link_to "View Full Post", post_path(post), class: "text-blue-900 hover:text-yellow-400 text-sm" %>

        <% if post.user == current_user %>
          <%= button_to "Delete", post_path(post),
              method: :delete,
              class: "px-2 py-1 text-sm bg-red-500 text-white rounded hover:bg-red-400" %>
        <% end %>
      </div>

    </div>
  <% end %>

</div>