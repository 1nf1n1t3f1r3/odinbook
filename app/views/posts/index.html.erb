<%# <h1>Posts#index</h1>
<p>Find me in app/views/posts/index.html.erb</p> %>

<div class="container-main">
  <div class="layout-3col">
    <!-- LEFT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Navigation</h2>
        <p class="text-sm opacity-70">Links coming later</p>
      </div>
    </aside>

<main>
  <!-- Create Post -->
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">Create a Post</h1>
    <%= form_with model: Post.new, url: posts_path, class: "flex flex-col gap-3" do |f| %>
      <%= f.text_area :content, placeholder: "What's on your mind?",
            class: "input"%>
      <%= f.submit "Post", class: "btn btn-primary self-end" %>
    <% end %>
  </div>

  <!-- Feed -->
  <h1 class="text-2xl font-bold text-primary-blue-dark mb-4">Feed</h1>

  <% @posts.each do |post| %>
	<div class="card card-hover mb-4">
      
      <div class="flex justify-between items-center mb-2">
        <strong>
          <%= link_to post.user.username, user_path(post.user),
                class: "text-primary-blue-dark font-semibold hover:text-accent-yellow" %>
        </strong>
        <small class="text-gray-600">
          <%= time_ago_in_words(post.created_at) %> ago
        </small>
      </div>

      <p class="mb-2"><%= post.content %></p>

      <div class="flex gap-2">
        <%= link_to "View Post", post_path(post), class: "btn btn-secondary text-sm" %>

        <% if post.user == current_user %>
          <%= button_to "Delete Post", post_path(post),
              method: :delete,
                 class: "btn btn-danger text-sm" %>
        <% end %>
      </div>

    </div>
  <% end %>
	
</main>

    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Suggestions</h2>
        <p class="text-sm opacity-70">Future: who to follow</p>
      </div>
    </aside>

	  </div>
</div>


