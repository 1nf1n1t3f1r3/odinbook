<%# <h1>Posts#index</h1>
<p>Find me in app/views/posts/index.html.erb</p> %>
<div class="container-main">
  <div class="layout-3col">
    <!-- LEFT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Navigation</h2>
        <p class="text-sm opacity-70">Links coming later</p>
      </div>
    </aside>
    <main>
      <!-- Create Post -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">Create a Post</h1>
      <%= render "posts/create_post" %>
      <!-- Feed -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-4">Feed</h1>
      <%# 1. We name this container so Turbo knows exactly where to append subsequent pages %>
      <div id="posts-feed-container">
        <% @posts.each do |post| %>
          <%= render post %>
        <% end %>
      </div>
      <%# 2. We trap the pagination navigation inside a unique Turbo Frame %>
      <%= turbo_frame_tag "pagy_pagination_frame" do %>
        <% if @pagy.next %>
          <div class="pagy-nav my-6 text-center">
            <%# We add data-turbo-stream to force the link to fetch a stream rather than an HTML page %>
            <%= link_to "Load More Posts", 
                        posts_path(page: @pagy.next), 
                        data: { turbo_stream: true }, 
                        class: "btn btn-secondary inline-block px-4 py-2" %>
          </div>
        <% end %>
      <% end %>
    </main>
    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Suggestions</h2>
        <p class="text-sm opacity-70">Future: who to follow</p>
      </div>
    </aside>
  </div>
</div>
