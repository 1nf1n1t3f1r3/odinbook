<%# <h1>Posts#index</h1>
<p>Find me in app/views/posts/index.html.erb</p> %>
<div class="container-main">
  <div class="layout-3col">
    <!-- LEFT SIDEBAR -->
    <aside>
      <%= render "shared/left_sidebar" %>
    </aside>
    <main>
      <!-- Create Post -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">Create a Post</h1>
      <%= render "posts/create_post" %>
      <!-- Feed -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-4">Feed</h1>
      <%# 1. We name this container so Turbo knows exactly where to append subsequent pages %>
      <div id="posts-feed-container">
        <% @posts.each do |post| %>
          <%= render post %>
        <% end %>
      </div>
      <%# 2. We trap the pagination navigation inside a unique Turbo Frame with Stimulus and data-infinite-scroll-target %>
      <%# We style it invisibly since the user won't need to manually click it %>
      <%= turbo_frame_tag "pagy_pagination_frame" do %>
        <% if @pagy.next %>
          <%# 1. We connect the wrapper element to our Stimulus controller %>
          <div data-controller="infinite-scroll" class="my-8 text-center py-4">
            <%= link_to "Loading more posts...", 
                  posts_path(page: @pagy.next), 
                  data: { 
                    turbo_stream: true,
                    infinite_scroll_target: "link" 
                  }, 
                  class: "text-gray-500 text-sm tracking-wide animate-pulse" %>
          </div>
        <% end %>
      <% end %>
    </main>
    <!-- RIGHT SIDEBAR -->
    <aside>
      <%= render "shared/advertisement" %>
    </aside>
  </div>
</div>
