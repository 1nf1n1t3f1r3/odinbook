<div class="container-main">
  <div class="layout-3col">

    <!-- LEFT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Navigation</h2>
        <p class="text-sm opacity-70">Links coming later</p>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="space-y-6">

      <!-- POST TITLE -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">
        Post
      </h1>

      <!-- POST CARD -->
      <div class="card card-hover">
        <div class="mb-4">
          <strong>
            <%= link_to @post.user.username,
                        user_path(@post.user),
                        class: "text-primary-blue-dark hover:text-accent-yellow font-semibold" %>
          </strong>
        </div>

        <p class="mb-4 text-base">
          <%= @post.content %>
        </p>

        <small class="block opacity-60 mb-4">
          Posted <%= time_ago_in_words(@post.created_at) %> ago
        </small>

        <!-- ACTIONS -->
        <div class="flex gap-2">
          <%= link_to "Back to feed",
                      root_path,
                      class: "btn btn-primary" %>

          <% if @post.user == current_user %>
            <%= button_to "Delete Post",
                          post_path(@post),
                          method: :delete,
                          class: "btn btn-danger" %>
          <% end %>
        </div>
      </div>

      <!-- COMMENTS TITLE -->
      <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">
        Comments
      </h1>

      <!-- COMMENTS LIST -->
      <% @post.comments.each do |comment| %>
        <div class="card card-hover mb-4">

          <!-- Username -->
		<div class="mb-1 font-semibold">
		<%= link_to comment.user.username,
					user_path(comment.user),
					class: "text-primary-blue-dark hover:text-accent-yellow" %>
		</div>

          <!-- Content + delete -->
		<div class="flex flex-col gap-2">
            <div class="flex-1 text-left min-w-0">
              <%= simple_format(comment.content) %>
            </div>

			<div class="flex gap-3 mt-3 text-sm opacity-70">


			<button class="btn btn-secondary" >
				Reply
			</button>

			<button class="btn btn-secondary" >
				Like
			</button>

			<button class="btn btn-secondary" >
				Share
			</button>

			<% if comment.user == current_user %>
            <%= button_to "Delete",
                            post_comment_path(@post, comment),
                            method: :delete,
                            class: "btn btn-danger" %>
            <% end %>
			</div>


          </div>

        </div>
      <% end %>

      <!-- CREATE COMMENT -->
      <div class="mb-6">
        <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">
          Create a Comment
        </h1>

        <%= form_with(model: [@post, Comment.new], local: true) do |f| %>
          <%= f.text_area :content,
                          placeholder: "What do you want to Comment?",
						  rows: 4,
                          class: "input",
						  data: { controller: "autosize" } %>

          <%= f.submit "Comment",
                       class: "btn btn-primary self-end" %>
        <% end %>
      </div>

      <!-- BACK LINK -->
      <div>
        <%= link_to "Back to feed",
                    root_path,
                    class: "btn btn-primary self-end" %>
      </div>

    </main>

    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Post Info</h2>
        <p class="text-sm opacity-70">
          Future: likes, comments, stats
        </p>
      </div>
    </aside>

  </div>
</div>