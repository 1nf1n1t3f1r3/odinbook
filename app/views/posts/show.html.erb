<div class="container-main">

  <div class="layout-3col">

    <!-- LEFT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Navigation</h2>
        <p class="text-sm opacity-70">Links coming later</p>
      </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="space-y-6">

    <h1 class="text-2xl font-bold text-primary-blue-dark mb-2">Post</h1>

      <!-- POST CARD -->
      <div class="card card-hover">

        <div class="mb-4">
          <strong>
            <%= link_to @post.user.username,
                        user_path(@post.user),
                        class: "text-primary-blue-dark hover:text-accent-yellow font-semibold" %>
          </strong>
        </div>

        <p class="mb-4 text-base">
          <%= @post.content %>
        </p>

        <small class="block opacity-60 mb-4">
          Posted <%= time_ago_in_words(@post.created_at) %> ago
        </small>

        <!-- ACTIONS -->
        <div class="flex gap-2">

          <%= link_to "Back to feed",
                      root_path,
                      class: "btn btn-primary" %>

          <% if @post.user == current_user %>
            <%= button_to "Delete Post",
                          post_path(@post),
                          method: :delete,
                          class: "btn btn-danger" %>
          <% end %>

        </div>

		

      </div>

	<h1 class="mt-6 font-bold">Comments</h2>

	<% @post.comments.each do |comment| %>
	<div class="border-b py-2">
		<strong><%= comment.user.username %></strong>
		<p><%= comment.content %></p>

		<% if comment.user == current_user %>
		<%= button_to "Delete", post_comment_path(@post, comment), method: :delete %>
		<% end %>
	</div>
	<% end %>

	<h1 class="mt-4">Add a comment</h3>

	<%= form_with(model: [@post, Comment.new], local: true) do |form| %>
	<div>
		<%= form.text_area :content, rows: 3 %>
	</div>

	<div>
		<%= form.submit "Post Comment" %>
	</div>
	<% end %>




    </main>

    <!-- RIGHT SIDEBAR -->
    <aside>
      <div class="card">
        <h2 class="font-semibold mb-2">Post Info</h2>
        <p class="text-sm opacity-70">
          Future: likes, comments, stats
        </p>
      </div>
    </aside>

  </div>

</div>