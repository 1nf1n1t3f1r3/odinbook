<%# app/views/posts/_post.html.erb %>

<div class="card card-hover mb-4">
  <div class="flex items-center gap-3">
    
    <%# Avatar %>
    <% if post.user.avatar.attached? %>
      <%= image_tag post.user.avatar,
        class: "w-12 h-12 rounded-full object-cover" %>
    <% end %>

    <%# User info %>
    <div>
      <%= link_to post.user.username,
        user_path(post.user),
        class: "text-primary-blue-dark font-semibold hover:text-accent-yellow" %>

      <p class="text-xs text-gray-500">
        @<%= post.user.username %>
      </p>
    </div>
		<small class="text-gray-600">
			<%= time_ago_in_words(post.created_at) %> ago
		</small>
  	</div>


	<%# Content %>
	<p class="mb-2"><%= post.content %></p>

	<%# Image %>
	<% if post.image.attached? %>
		<%= link_to post_path(post) do %>
			<%= image_tag post.image,
				class: "rounded-lg mt-2 max-h-48 object-cover mb-4" %>
		<% end %>
	<% end %>

	<div class="flex gap-2 mb-2">
		<%= link_to "View Post", post_path(post), class: "btn btn-secondary text-sm" %>

		<% if post.user == current_user %>
			<%= button_to "Delete Post", post_path(post),
				method: :delete,
					class: "btn btn-danger text-sm" %>
		<% end %>
	</div>

	<%# 👇 LIKES %>
	<%= render "likes/like_button", post: post %>

	<%# COMMENTS %>
	<%= render "comments/create_comment_inline", post: post %>
</div>